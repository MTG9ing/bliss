{
  "name": "@mtg9ing/bliss",
  "version": "2.1.0",
  "description": "The automated backend architect for Node.js and Bun",
  "author": "Mohammed Ghazy <mtg9ing@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/MTG9ing/bliss",
  "repository": {
    "type": "git",
    "url": "https://github.com/MTG9ing/bliss.git"
  },
  "type": "module",
  "module": "src/cli/index.ts",
  "main": "dist/cli/index.js",
  "bin": {
    "bliss": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "src/templates"
  ],
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "backend",
    "express",
    "fastify",
    "scaffold",
    "boilerplate",
    "bliss"
  ],
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --outdir dist --target bun",
    "build:bin": "bun build --compile src/cli/index.ts --outfile dist/bliss",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "check": "biome check .",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "citty": "^0.2.2",
    "magic-string": "^0.30.21",
    "sucrase": "3.35.1",
    "yoctocolors": "^2.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest",
    "vitest": "latest"
  }
}