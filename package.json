{
  "files": [
    "dist",
    "src/templates",
    "src/modules/built-in"
  ],
  "bin": {
    "bliss": "dist/index.js"
  },
  "name": "@mtg9ing/bliss",
  "version": "2.0.2",
  "module": "src/index.ts",
  "main": "dist/index.js",
  "type": "module",
  "homepage": "https://mtg9ing.github.io/bliss/",
  "author": "Mohammed Ghazy <mtg9ing@gmail.com>",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "bundle-templates": "bun run scripts/bundle-templates.ts",
    "bundle-modules": "bun run scripts/bundle-modules.ts",
    "build:bin": "bun run bundle-templates && bun run bundle-modules && bun build --compile src/index.ts --outfile dist/bliss",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "check": "biome check .",
    "prepublishOnly": "bun run bundle-templates && bun run bundle-modules && bun run build"
  },
  "keywords": [
    "cli",
    "backend",
    "express",
    "developer-experience",
    "automation",
    "bliss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MTG9ing/bliss.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest",
    "@types/handlebars": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "citty": "^0.2.2",
    "handlebars": "^4.7.9",
    "magic-string": "^0.30.21",
    "yoctocolors": "^2.1.2",
    "zod": "^4.4.3"
  }
}
