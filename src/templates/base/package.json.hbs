{
  "name": "{{lowercase projectName}}",
  "version": "1.0.0",
  "description": "Generated by Bliss CLI",
  "main": "{{#if (eq language "typescript")}}dist/index.js{{else}}src/index.js{{/if}}",
  "type": "module",
  "scripts": {
    "start": "{{#if (eq packageManager "bun")}}bun{{else}}node{{/if}} {{#if (eq language "typescript")}}dist/index.js{{else}}src/index.js{{/if}}",
    "dev": "{{#if (eq packageManager "bun")}}bun --hot{{else if (eq language "typescript")}}tsx watch{{else}}node --watch{{/if}} src/index.{{language}}",
    "build": "{{#if (eq language "typescript")}}tsc{{else}}echo 'No build step needed'{{/if}}",
    "lint": "{{#if features.eslint}}eslint src/{{else}}echo 'No linter configured'{{/if}}",
    "format": "{{#if features.prettier}}prettier --write src/{{else}}echo 'No formatter configured'{{/if}}",
    "test": "{{#if features.tests}}vitest{{else}}echo 'No tests configured'{{/if}}"
  },
  "keywords": ["backend", "{{framework}}", "api"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "{{framework}}": "latest"
  },
  "devDependencies": {
    {{#if (eq framework "express")}}
    {{#if (eq language "typescript")}}
    "@types/express": "^4.17.0",
    {{/if}}
    {{/if}}
    {{#if features.tests}}
    "vitest": "^1.0.0",
    {{/if}}
    {{#if features.prettier}}
    "prettier": "^3.0.0",
    {{/if}}
    {{#if features.eslint}}
    "eslint": "^9.0.0",
    {{/if}}
    {{#if (eq language "typescript")}}
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
    {{/if}}
  }
}